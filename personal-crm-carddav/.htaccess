# Personal CRM CardDAV - Apache Configuration
# Ensures HTTP Authorization headers are passed to WordPress

<IfModule mod_rewrite.c>
RewriteEngine On

# Pass HTTP Authorization header to PHP
RewriteCond %{HTTP:Authorization} ^(.*)
RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]

# Alternative method for some server configurations
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>

# Allow OPTIONS requests (CORS preflight)
<IfModule mod_headers.c>
Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS, PROPFIND, REPORT"
Header always set Access-Control-Allow-Headers "Authorization, Content-Type, Depth, User-Agent, X-Requested-With, If-Match, If-None-Match"
</IfModule>
